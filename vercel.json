{
    "version": 2,
    "framework": null,
    "functions": {
        "public/index.php": {
            "runtime": "vercel-php@0.6.1"
        }
    },
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/public/index.php?url=$1"
        }
    ],
    "env": {
        "DB_DRIVER": "pgsql",
        "DB_HOST": "YOUR_SUPABASE_DB_HOST",
        "DB_USER": "postgres",
        "DB_PASS": "YOUR_SUPABASE_DB_PASSWORD",
        "DB_NAME": "postgres",
        "DB_PORT": "5432"
    }
}
